{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/*.mjs": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/publish-scheduled",
      "schedule": "* * * * *"
    }
  ]
}
